# ===========================================================================
#  Cogni-Threat — Backend environment template (PROPUESTO)
#  Copiá este archivo sobre .env.template:  cp env.template.proposed .env.template
#  Luego borralo:  rm env.template.proposed
# ===========================================================================

# ───────── Arranque (OBLIGATORIAS — nunca van al panel admin) ─────────
DATABASE_URL=postgresql://user:password@localhost:5432/cogni_threat
JWT_SECRET=
JWT_EXPIRES_IN=24h
# Master key para cifrar los secretos del panel admin (AES-256-GCM).
# Generar con: openssl rand -base64 32
SECRETS_MASTER_KEY=

# Credenciales de Postgres usadas por docker-compose (DATABASE_URL se arma con estas).
DB_USERNAME=cogni_user
DB_PASSWORD=
DB_DATABASE=cogni_threat

# Bootstrap del primer usuario admin (se crea/actualiza automáticamente al levantar la API).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ───────── App / red ─────────
NODE_ENV=development
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
# IPs permitidas separadas por coma (localhost siempre se permite).
ALLOWED_IPS=

# ───────── Secretos de fuentes (opcionales — se gestionan desde /admin/secrets) ─────────
# Funcionan como fallback si no están cargados en el panel. Podés dejarlos
# vacíos y configurarlos desde la UI una vez levantada la app.
NVD_API_KEY=
GITHUB_TOKEN=
RANSOMWARE_API_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
BOT_TOKEN=

# ───────── Config de fuentes (no secreta) ─────────
NVD_API_URL=https://services.nvd.nist.gov/rest/json
RANSOMWARE_API_URL=https://api-pro.ransomware.live
# Tras una caída prolongada, al boot se fuerza sync completo de ransomware (por país + grupos).
RANSOMWARE_RECOVERY_STALE_HOURS=24
RANSOMWARE_RECOVERY_ON_BOOT=true
# Canales de Telegram a monitorear (coma-separados, ej: @canal1,@canal2)
TELEGRAM_CHANNEL_USERNAME=

# ───────── IA / RAG (Ollama) ─────────
OLLAMA_URL=http://localhost:11434
MODEL=gpt-oss
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_DIM=4096
OLLAMA_TIMEOUT_MS=180000
RAG_RETRIEVE_CANDIDATES=20
RAG_CHAT_TEMPERATURE=0.2
RAG_CHAT_NUM_CTX=32768
RAG_QUERY_MAX_CHARS=3500
# RAG_QUERY_INSTRUCT tiene un default en el código; descomentá solo si querés override.
# RAG_QUERY_INSTRUCT=
