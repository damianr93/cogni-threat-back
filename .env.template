# ===========================================================================
#  Cogni-Threat — Backend environment template
#  Copiá este archivo a .env y completá los valores marcados como obligatorios.
#  Todo lo demás (API keys de fuentes, Telegram, Ollama/RAG) se configura
#  desde el panel admin una vez que la app está arriba — no hace falta
#  tocar este archivo para eso.
# ===========================================================================

# ───────── OBLIGATORIAS para arrancar ─────────

# Solo se usa si corrés la API sin Docker (pnpm run start:dev). Con
# docker-compose se ignora: la URL se arma con DB_USERNAME/DB_PASSWORD/DB_DATABASE.
DATABASE_URL=postgresql://user:password@localhost:5432/cogni_threat

JWT_SECRET=
JWT_EXPIRES_IN=24h

# Master key para cifrar los secretos del panel admin (AES-256-GCM).
# Generar con: openssl rand -base64 32
SECRETS_MASTER_KEY=

# Credenciales de Postgres usadas por docker-compose (DATABASE_URL se arma con estas).
DB_USERNAME=cogni_user
DB_PASSWORD=
DB_DATABASE=cogni_threat

# Bootstrap del primer usuario admin (se crea/actualiza automáticamente al levantar la API).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ───────── App / red (tienen default, tocar solo si hace falta) ─────────
NODE_ENV=development
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
# IPs permitidas separadas por coma (localhost siempre se permite).
ALLOWED_IPS=

# ───────── Todo lo demás: panel admin (Administración → Fuentes, credenciales e IA) ─────────
# NVD_API_KEY, GITHUB_TOKEN, RANSOMWARE_API_KEY, TELEGRAM_API_ID, TELEGRAM_API_HASH,
# TELEGRAM_SESSION_STRING, BOT_TOKEN, la URL de Ollama, el modelo de chat/embeddings
# y los parámetros de RAG se cargan desde ahí sin reiniciar el contenedor. El código
# trae defaults razonables (Ollama en host.docker.internal, modelos gpt-oss /
# qwen3-embedding) para que funcione sin tocar nada. Descomentá y completá acá
# abajo solo si preferís fijarlos por variable de entorno en vez del panel.
# NVD_API_KEY=
# GITHUB_TOKEN=
# RANSOMWARE_API_KEY=
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION_STRING=
# BOT_TOKEN=
# OLLAMA_URL=
# MODEL=
# EMBEDDING_MODEL=

# EMBEDDING_DIM es la única excepción real: vive en el esquema de Postgres
# (columna vector de pgvector), no se gestiona desde el panel. Tocalo solo si
# cambiás a un modelo de embeddings con otra dimensión, y antes de indexar
# datos (o reindexá después).
EMBEDDING_DIM=4096
