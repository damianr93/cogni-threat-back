{
  "name": "cogni-threat",
  "version": "0.0.3",
  "description": "Cogni-Threat Intelligence Platform",
  "author": "Daniel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/daniel3736/cogni-threat.git"
  },
  "bugs": {
    "url": "https://github.com/daniel3736/cogni-threat/issues"
  },
  "homepage": "https://github.com/daniel3736/cogni-threat#readme",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "build:prod": "prisma generate && nest build",
    "lint": "eslint \"{src,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "ingest:actors": "ts-node scripts/ingest-actors.ts",
    "ingest:fake-news": "ts-node scripts/ingest-fake-news.ts",
    "ingest:hitos": "ts-node scripts/ingest-hitos.ts",
    "ingest:hitos2": "ts-node scripts/ingest-hitos.ts hitos-por-grupos2.json",
    "fix:duplicate-actors": "ts-node scripts/fix-duplicate-actors.ts",
    "fix:strip-urls-from-descriptions": "ts-node scripts/strip-urls-from-descriptions.ts",
    "seed:vuln": "ts-node scripts/seed-vuln.ts",
    "seed:admin": "ts-node scripts/seed-admin.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.7",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.7",
    "@nestjs/platform-express": "^11.1.7",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/terminus": "^11.0.7",
    "@prisma/client": "^6.2.0",
    "axios": "^1.7.7",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "env-var": "^7.5.0",
    "multer": "^2.2.0",
    "nestjs-zod": "^3.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.22.0",
    "prisma": "^6.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "telegram": "^2.25.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "form-data": "^4.0.6",
      "multer": "^2.2.0",
      "qs": "^6.15.2"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^libs/(.*)$": "<rootDir>/libs/$1",
      "^@test/(.*)$": "<rootDir>/test/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/"
    ]
  }
}
